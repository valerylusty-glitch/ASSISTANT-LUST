# Copie ce fichier en ".env" et remplis les valeurs réelles.
# Ne commit JAMAIS le fichier .env (il contient des secrets).

# Token du bot, obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Clé API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Modèle Claude utilisé pour les réponses
ANTHROPIC_MODEL=claude-sonnet-4-6

# Nom d'utilisateur du bot sur Telegram (sans le @)
BOT_USERNAME=YOKUBO

# ID Telegram de l'administrateur autorisé à utiliser /broadcast
ADMIN_ID=8305367220

# ID du canal/groupe développeur ciblé par /broadcast
CHANNEL_ID=-1004390236547
